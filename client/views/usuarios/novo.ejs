<!DOCTYPE html>
<html lang="pt-br">
<head>
    <%- include('../partials/head', { titulo: 'LifeStock - Novo Usuário' }) %>
</head>
<body class="dashboard-page">

    <%- include('../partials/header') %>

    <main class="dashboard-main">
        <h1 class="form-page-title">Novo usuário</h1>
        <p class="form-page-subtitle">Crie um novo usuário e defina seu perfil de acesso.</p>

        <div class="form-card">
            <form action="/usuarios/novo" method="POST">

                <div class="form-group">
                    <label for="nome">Nome completo</label>
                    <input class="form-control" type="text" id="nome" name="nome" required maxlength="65">
                </div>

                <div class="form-group">
                    <label for="email">E-mail</label>
                    <input class="form-control" type="email" id="email" name="email" required maxlength="65">
                </div>

                <div class="form-group">
                    <label for="senha">Senha</label>
                    <input class="form-control" type="password" id="senha" name="senha" required minlength="6">
                </div>

                <div class="form-group">
                    <label for="confirmar_senha">Confirmar senha</label>
                    <input class="form-control" type="password" id="confirmar_senha" name="confirmar_senha" required minlength="6">
                </div>

                <div class="form-group">
                    <label for="perfil">Perfil</label>
                    <select id="perfil" name="perfil" class="form-control">
                        <option value="1">Funcionário</option>
                        <option value="2">Administrador</option>
                    </select>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-novo-produto">Criar usuário</button>
                    <a href="/usuarios/gerenciar" class="btn-secondary-action">Voltar</a>
                </div>

            </form>
        </div>
    </main>

</body>
</html>
