<!DOCTYPE html>
<html lang="pt-br">
<head>
    <%- include('../partials/head', { titulo: 'LifeStock - Editar Usuário (Admin)' }) %>
</head>
<body class="dashboard-page">

    <%- include('../partials/header') %>

    <main class="dashboard-main">
        <h1 class="form-page-title">Editar usuário</h1>
        <p class="form-page-subtitle">Atualize os dados do usuário selecionado.</p>

        <div class="form-card">
            <form action="/usuarios/<%= usuarioEd.id_usuario %>/atualizar" method="POST">

                <div class="form-group">
                    <label for="nome">Nome completo</label>
                    <input class="form-control" type="text" id="nome" name="nome" value="<%= usuarioEd.nome %>" required maxlength="65">
                </div>

                <div class="form-group">
                    <label for="email">E-mail</label>
                    <input class="form-control" type="email" id="email" name="email" value="<%= usuarioEd.email %>" required maxlength="65">
                </div>

                <div class="form-group">
                    <label for="senha">Nova senha (opcional)</label>
                    <input class="form-control" type="password" id="senha" name="senha" minlength="6">
                </div>

                <div class="form-group">
                    <label for="confirmar_senha">Confirmar nova senha</label>
                    <input class="form-control" type="password" id="confirmar_senha" name="confirmar_senha" minlength="6">
                </div>

                <div class="form-group">
                    <label for="perfil">Perfil</label>
                    <select id="perfil" name="perfil" class="form-control">
                        <option value="1" <%= usuarioEd.id_perfil === 1 ? 'selected' : '' %>>Funcionário</option>
                        <option value="2" <%= usuarioEd.id_perfil === 2 ? 'selected' : '' %>>Administrador</option>
                    </select>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-novo-produto">Salvar</button>
                    <a href="/usuarios/gerenciar" class="btn-secondary-action">Voltar</a>
                    <a href="/home" class="btn-secondary-action">Voltar ao dashboard</a>
                </div>

            </form>
        </div>
    </main>

</body>
</html>
