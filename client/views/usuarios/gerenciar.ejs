<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LifeStock - Gerenciar Usuários</title>
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body class="dashboard-page">
    <%- include('../partials/header') %>

    <div class="dashboard-main">
        <div class="toolbar">
            <a href="/usuarios/novo" class="btn-novo-produto"><i class="fa-solid fa-plus"></i> Novo Usuário</a>
        </div>

        <section class="tabela-container">
            <table class="tabela-estoque">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>E-mail</th>
                        <th>Perfil</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (usuarios.length === 0) { %>
                        <tr>
                            <td colspan="5" class="tabela-vazia">Nenhum usuário cadastrado.</td>
                        </tr>
                    <% } else { %>
                        <% usuarios.forEach(function(u) { %>
                            <tr>
                                <td><%= u.id_usuario %></td>
                                <td><%= u.nome_usuario || u.nome %></td>
                                <td><%= u.email_usuario || u.email %></td>
                                <td><%= u.nome_perfil || u.perfil %></td>
                                <td>
                                    <a href="/usuarios/<%= u.id_usuario %>/editar" class="btn" style="background:#4a6cf7;border:none;margin-right:8px;padding:8px 12px">Editar</a>
                                    <form action="/usuarios/<%= u.id_usuario %>/excluir" method="POST" style="display:inline" onsubmit="return confirm('Confirma exclusão deste usuário?')">
                                        <button type="submit" class="btn" style="background:#e74c3c;border:none;margin-left:8px;padding:8px 12px">Excluir</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </section>
    </div>
</body>
</html>