<!DOCTYPE html>
<html lang="pt-br">
<head>
    <%- include('../partials/head', { titulo: 'LifeStock - Gerenciar Usuários' }) %>
</head>
<body class="dashboard-page">

    <%- include('../partials/header') %>

    <main class="dashboard-main">
        <div class="toolbar">
            <a href="/usuarios/novo" class="btn-novo-produto"><i class="fa-solid fa-plus"></i> Novo Usuário</a>
        </div>

        <section class="tabela-container">
            <table class="tabela-estoque">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>E-mail</th>
                        <th>Perfil</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (usuarios.length === 0) { %>
                        <tr>
                            <td colspan="5" class="tabela-vazia">Nenhum usuário cadastrado.</td>
                        </tr>
                    <% } else { %>
                        <% usuarios.forEach(function(u) { %>
                            <tr>
                                <td><%= u.id_usuario %></td>
                                <td><%= u.nome_usuario || u.nome %></td>
                                <td><%= u.email_usuario || u.email %></td>
                                <td><%= u.nome_perfil || u.perfil %></td>
                                <td>
                                    <div class="acoes-cell">
                                        <a href="/usuarios/<%= u.id_usuario %>/editar" class="btn-acao btn-acao-editar">Editar</a>
                                        <form action="/usuarios/<%= u.id_usuario %>/excluir" method="POST" onsubmit="return confirm('Confirma exclusão deste usuário?')">
                                            <button type="submit" class="btn-acao btn-acao-excluir">Excluir</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </section>
    </main>

</body>
</html>
