<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LifeStock - Editar Usuário</title>
    <link rel="stylesheet" href="/css/login.css">
    <link href="https://fonts.googleapis.com/css2?family=Patrick+Hand&display=swap" rel="stylesheet">
</head>
<body class="login-page cadastro-page">

    <div class="container">

        <div class="left">
            <div class="logo">
                <h1>Life Stock</h1>
            </div>

            <div class="texto">
                <h2>Perfil</h2>
                <p>
                    Atualize seus dados de administrador <br>
                    ou altere sua senha de acesso.
                </p>
            </div>

            <div class="buttons">
                <button type="button" class="btn-ativo">EDITAR</button>
                <a href="/home">VOLTAR</a>
            </div>
        </div>

        <div class="right">
            <form class="login-box" action="/usuarios/atualizar" method="POST">

                <% if (typeof sucesso !== 'undefined' && sucesso) { %>
                    <div class="alerta alerta-sucesso">
                        Dados atualizados com sucesso!
                    </div>
                <% } %>

                <input type="text" id="nome" name="nome" placeholder="NOME COMPLETO" maxlength="65" value="<%= usuario.nome %>" required>

                <input type="email" id="email" name="email" placeholder="E-MAIL" maxlength="65" value="<%= usuario.email %>" required>

                <input type="password" id="senha" name="senha" placeholder="NOVA SENHA (opcional)" minlength="6">

                <input type="password" id="confirmar_senha" name="confirmar_senha" placeholder="CONFIRMAR NOVA SENHA" minlength="6">

                <button type="submit" class="btn">SALVAR ALTERAÇÕES</button>

            </form>
        </div>

    </div>

</body>
</html>
