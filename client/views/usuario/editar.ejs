<!DOCTYPE html>
<html lang="pt-br">
<head>
    <%- include('../partials/head', { titulo: 'LifeStock - Editar Perfil' }) %>
</head>
<body class="dashboard-page">

    <%- include('../partials/header') %>

    <main class="dashboard-main">
        <h1 class="form-page-title">Meu perfil</h1>
        <p class="form-page-subtitle">Atualize seus dados ou altere sua senha de acesso.</p>

        <div class="form-card">
            <form action="/usuarios/atualizar" method="POST">

                <% if (typeof sucesso !== 'undefined' && sucesso) { %>
                    <div class="alerta alerta-sucesso">
                        Dados atualizados com sucesso!
                    </div>
                <% } %>

                <div class="form-group">
                    <label for="nome">Nome completo</label>
                    <input class="form-control" type="text" id="nome" name="nome" maxlength="65" value="<%= usuario.nome %>" required>
                </div>

                <div class="form-group">
                    <label for="email">E-mail</label>
                    <input class="form-control" type="email" id="email" name="email" maxlength="65" value="<%= usuario.email %>" required>
                </div>

                <div class="form-group">
                    <label for="senha">Nova senha (opcional)</label>
                    <input class="form-control" type="password" id="senha" name="senha" minlength="6">
                </div>

                <div class="form-group">
                    <label for="confirmar_senha">Confirmar nova senha</label>
                    <input class="form-control" type="password" id="confirmar_senha" name="confirmar_senha" minlength="6">
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-novo-produto">Salvar alterações</button>
                    <a href="/home" class="btn-secondary-action">Voltar</a>
                </div>

            </form>
        </div>
    </main>

</body>
</html>
