<!DOCTYPE html>
<html lang="pt-br">
<head>
    <%- include('../partials/head', { titulo: 'LifeStock - Estoque' }) %>
</head>
<body class="dashboard-page">

    <%- include('../partials/header') %>

    <main class="dashboard-main">
        <div class="toolbar">
            <form action="/home" method="GET">
                <div class="toolbar-input">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" name="busca" placeholder="Buscar produto ou categoria" value="<%= busca %>">
                </div>

                <div class="toolbar-input">
                    <i class="fa-solid fa-filter"></i>
                    <select name="filtro">
                        <option value="" <%= filtro === '' ? 'selected' : '' %>>Todos</option>
                        <option value="proximo" <%= filtro === 'proximo' ? 'selected' : '' %>>Próximo vencimento</option>
                        <option value="vencido" <%= filtro === 'vencido' ? 'selected' : '' %>>Vencidos</option>
                        <option value="em_dia" <%= filtro === 'em_dia' ? 'selected' : '' %>>Em dia</option>
                    </select>
                </div>

                <button type="submit" class="btn-novo-produto">Buscar</button>

                <% if (ehAdmin) { %>
                    <a href="/produtos/cadastrar" class="btn-novo-produto"><i class="fa-solid fa-plus"></i> Novo Produto</a>
                <% } %>
            </form>
        </div>

        <div class="resumo-grid">
            <div class="resumo-card azul">
                <div>
                    <h3>Total em estoque</h3>
                    <div class="numero"><%= resumo.total_estoque || 0 %></div>
                </div>
                <i class="fa-solid fa-boxes"></i>
            </div>

            <div class="resumo-card laranja">
                <div>
                    <h3>Próximo vencimento</h3>
                    <div class="numero"><%= resumo.proximo_validade || 0 %></div>
                </div>
                <i class="fa-solid fa-hourglass-half"></i>
            </div>

            <div class="resumo-card vermelho">
                <div>
                    <h3>Vencidos</h3>
                    <div class="numero"><%= resumo.vencidos || 0 %></div>
                </div>
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
        </div>

        <section class="tabela-container" style="margin-top:18px;">
            <table class="tabela-estoque">
                <thead>
                    <tr>
                        <th>Lote</th>
                        <th>Produto</th>
                        <th>Categoria</th>
                        <th>Quantidade</th>
                        <th>Validade</th>
                        <th>Status</th>
                        <% if (ehAdmin) { %><th>Ações</th><% } %>
                    </tr>
                </thead>
                <tbody>
                    <% if (!produtos || produtos.length === 0) { %>
                        <tr>
                            <td colspan="7" class="tabela-vazia">Nenhum produto encontrado.</td>
                        </tr>
                    <% } else { %>
                        <% produtos.forEach(function(p) { %>
                            <tr>
                                <td><%= p.lote_formatado || (p.id_lote ? String(p.id_lote).padStart(3,'0') : '-') %></td>
                                <td>
                                    <div class="produto-cell">
                                        <div class="produto-icon"><i class="fa-solid fa-box"></i></div>
                                        <div>
                                            <div><%= p.nome_produto %></div>
                                        </div>
                                    </div>
                                </td>
                                <td><%= p.categoria_produto || '-' %></td>
                                <td><%= p.quantidade %></td>
                                <td class="validade-cell">
                                    <%= p.validade_formatada %>
                                    <span class="validade-relativa"><%= p.validade_relativa %></span>
                                </td>
                                <td><span class="status-badge <%= p.status_classe %>"><%= p.status_label %></span></td>
                                <% if (ehAdmin) { %>
                                    <td>
                                        <div class="acoes-cell">
                                            <a href="/produtos/<%= p.id_produto %>/movimentar" class="btn-acao btn-acao-editar">Movimentar</a>
                                            <a href="/produtos/<%= p.id_produto %>/editar" class="btn-acao btn-acao-editar">Editar</a>
                                            <form action="/produtos/<%= p.id_produto %>/desativar" method="POST" style="display:inline;" onsubmit="return confirm('Deseja desativar este produto?');">
                                                <button type="submit" class="btn-acao btn-acao-excluir">Desativar</button>
                                            </form>
                                        </div>
                                    </td>
                                <% } %>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </section>

        <div class="paginacao">
            <% for (let i = 1; i <= totalPaginas; i++) { %>
                <a href="/home?pagina=<%= i %>&busca=<%= encodeURIComponent(busca || '') %>&filtro=<%= encodeURIComponent(filtro || '') %>" class="btn-novo-produto" style="background: <%= i === pagina ? '#0f186f' : 'var(--azul-principal)' %>; opacity: <%= i === pagina ? '1' : '0.9' %>"><%= i %></a>
            <% } %>
        </div>

    </main>

    <script src="/js/dashboard.js"></script>
</body>
</html>
