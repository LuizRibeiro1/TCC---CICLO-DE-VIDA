<!DOCTYPE html>
<html lang="pt-br">
<head>
    <%- include('../partials/head', { titulo: 'LifeStock - Movimentar Estoque' }) %>
</head>
<body class="dashboard-page">

    <%- include('../partials/header') %>

    <main class="dashboard-main">
        <h1 class="form-page-title">Movimentar estoque</h1>
        <p class="form-page-subtitle">Registre entradas ou saídas para o produto selecionado.</p>

        <div class="form-card">
            <form action="/produtos/<%= produto.id_produto %>/movimentar" method="POST">
                <div class="form-group">
                    <label for="tipo">Tipo de movimentação</label>
                    <select class="form-control" id="tipo" name="tipo" required>
                        <option value="">Selecione</option>
                        <option value="ENTRADA">Entrada</option>
                        <option value="SAIDA">Saída</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="quantidade">Quantidade</label>
                    <input class="form-control" type="number" id="quantidade" name="quantidade" min="1" required>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-novo-produto">Registrar</button>
                    <a href="/home" class="btn-secondary-action">Voltar</a>
                </div>
            </form>
        </div>
    </main>

</body>
</html>
