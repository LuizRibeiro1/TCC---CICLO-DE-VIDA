<!DOCTYPE html>
<html lang="pt-br">
<head>
    <%- include('../partials/head', { titulo: 'LifeStock - Novo Produto' }) %>
</head>
<body class="dashboard-page">

    <%- include('../partials/header') %>

    <main class="dashboard-main">
        <h1 class="form-page-title">Novo produto</h1>
        <p class="form-page-subtitle">Cadastre um produto e o lote inicial para incluir no controle de estoque.</p>

        <div class="form-card">
            <form action="/produtos/cadastrar" method="POST">

                <div class="form-group">
                    <label for="nome">Nome do produto</label>
                    <input class="form-control" type="text" id="nome" name="nome" maxlength="100" required>
                </div>

                <div class="form-group">
                    <label for="categoria">Categoria</label>
                    <input class="form-control" type="text" id="categoria" name="categoria" maxlength="45" required>
                </div>

                <div class="form-group">
                    <label for="quantidade">Quantidade</label>
                    <input class="form-control" type="number" id="quantidade" name="quantidade" min="1" required>
                </div>

                <div class="form-group">
                    <label for="validade">Validade</label>
                    <input class="form-control" type="date" id="validade" name="validade" required>
                </div>

                <div class="form-group">
                    <label for="fornecedor">Fornecedor (opcional)</label>
                    <input class="form-control" type="text" id="fornecedor" name="fornecedor" maxlength="45">
                </div>

                <div class="form-group">
                    <label for="preco">Preço (opcional)</label>
                    <input class="form-control" type="number" id="preco" name="preco" min="0" step="0.01">
                </div>

                <div class="form-group">
                    <label for="descricao">Descrição (opcional)</label>
                    <textarea class="form-control" id="descricao" name="descricao" rows="3"></textarea>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-novo-produto">Cadastrar produto</button>
                    <a href="/home" class="btn-secondary-action">Voltar</a>
                </div>

            </form>
        </div>
    </main>

</body>
</html>
