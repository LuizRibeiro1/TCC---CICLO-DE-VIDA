<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LifeStock - Login</title>
    <!-- Estilos da tela de autenticação (login e cadastro compartilham este arquivo) -->
    <link rel="stylesheet" href="/css/login.css">
    <link href="https://fonts.googleapis.com/css2?family=Patrick+Hand&display=swap" rel="stylesheet">
</head>
<body class="login-page">

    <div class="container">

        <!-- Painel esquerdo: marca e navegação -->
        <div class="left">
            <div class="logo">
                <h1>Life Stock</h1>
            </div>

            <div class="texto">
                <h2>Bem-vindo</h2>
                <p>
                    Acesse sua conta ou crie um novo <br>
                    cadastro para começar a usar a plataforma.
                </p>
            </div>

            <div class="buttons">
                <a href="/cadastro">CADASTRAR</a>
                <!-- Botão visual apenas; indica que estamos na tela de login -->
                <button type="button" class="btn-ativo">LOGIN</button>
            </div>
        </div>

        <!-- Painel direito: formulário enviado ao backend -->
        <div class="right">
            <form class="login-box" action="/usuarios/login" method="POST">

                <% if (typeof cadastro !== 'undefined' && cadastro) { %>
                    <!-- Exibido após criar conta (?cadastro=1 na URL) -->
                    <div class="alerta alerta-sucesso">
                        Conta criada com sucesso! Faça login para entrar.
                    </div>
                <% } %>

                <!-- name="email" e name="senha" devem coincidir com req.body no controller -->
                <input type="email" name="email" placeholder="E-MAIL" required>

                <input type="password" name="senha" placeholder="SENHA" required>

                <button type="submit">ENTRAR</button>
            </form>
        </div>

    </div>

</body>
</html>
