<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LifeStock - Cadastro</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/login.css">
</head>
<body class="login-page cadastro-page">

    <div class="container">

        <div class="left">
            <div class="logo">
                <span class="logo-leaf"><i class="fa-solid fa-leaf"></i></span>
                <h1>LifeStock</h1>
            </div>

            <div class="texto">
                <h2>Bem-vindo</h2>
                <p>
                    Acesse sua conta ou crie um novo <br>
                    cadastro para começar a usar a plataforma.
                </p>
            </div>

            <div class="buttons">
                <button type="button" class="btn-ativo">CADASTRAR</button>
                <a href="/login">LOGIN</a>
            </div>
        </div>

        <div class="right">
            <form class="login-box" action="/usuarios/cadastrar" method="POST">

                <input type="text" id="nome" name="nome" placeholder="NOME COMPLETO" maxlength="65" required>
                <input type="email" id="email" name="email" placeholder="E-MAIL" maxlength="65" required>
                <input type="password" id="senha" name="senha" placeholder="SENHA" minlength="6" required>
                <input type="password" id="confirmar_senha" name="confirmar_senha" placeholder="CONFIRMAR SENHA" minlength="6" required>

                <button type="submit">CADASTRAR</button>

            </form>
        </div>

    </div>

</body>
</html>
