<!-- importa o header -->
<%- include('../partials/header')  %>

<main>
    <div class="container">
        <div class="card"
        style="padding: 2rem; border: 2px solid var(--cor-borda); box-shadow: 6px 6px 0px var(--cor-borda); 
        background-color: var(--cor-fundo);">
            <h2 style="color: var(--cor-destaque); text-align: center; margin-bottom: 5px;"> 
                <i class="fa-solid fa-user-plus"></i>
                CRIAR NOVA CONTA 
            </h2>
            <p style="text-align: center; color: var(--cor-texto-secundario); margin-bottom: 1.5rem;">
                Novos usuários são cadastrados como funcionário.
            </p>

            <form action="/usuarios/cadastrar" method="post">
                <div class="form-group">
                    <label for="nome">
                        <i class="fa-solid fa-id-card"></i> Nome completo
                    </label>
                    <input type="text" id="nome" name="nome" class="form-control" maxlength="65" required>
                </div>

                <div class="form-group">
                    <label for="email">
                        <i class="fa-solid fa-envelope"></i> E-mail
                    </label>
                    <input type="email" id="email" name="email" class="form-control" maxlength="65" required>
                </div>

                <div class="form-group">
                    <label for="senha">
                        <i class="fa-solid fa-lock"></i> Senha
                    </label>
                    <input type="password" name="senha" id="senha" class="form-control" minlength="6" required>
                </div>

                <div class="form-group">
                    <label for="confirmar_senha">
                        <i class="fa-solid fa-lock"></i> Confirmar senha
                    </label>
                    <input type="password" name="confirmar_senha" id="confirmar_senha" class="form-control" minlength="6" required>
                </div>

                <button type="submit" class="btn btn-secondary" style="width: 100%; margin-top: 15px;">
                    <i class="fa-solid fa-check"></i> Cadastrar
                </button>

                <div style="text-align: center; margin-top: 20px;">
                    <a href="/login" style="color: var(--cor-texto-principal); font-weight: bold; text-decoration: none;">
                        Já tem conta? 
                        <span style="color: var(--cor-destaque); text-decoration: underline;"> 
                            Faça Login
                        </span>
                    </a>
                </div>
            </form>
        </div>
    </div>
</main>

<%- include('../partials/footer')  %>
